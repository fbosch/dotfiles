{              
  "layer": "top",
  "position": "bottom",
  "height": 45,
  "margin-left": 4,
  "margin-right": 4,
  "margin-bottom": 4,
  "exclusive": true,
  "start_hidden": true,
  "on-sigusr1": "show",
  "on-sigusr2": "hide",
  "passthrough": false,
  "mode": "dock",

  "modules-left": ["custom/startbutton", "hyprland/workspaces"],
  "modules-center": ["wlr/taskbar"],
  "modules-right": ["memory", "cpu", "custom/cpu_temp", "custom/gpu_temp", "tray", "pulseaudio", "hyprland/language", "clock", "custom/swaync"],

  "tray": {
    "spacing": 8,
    "icon-size": 16,
    "reverse-direction": false,
  },

  "custom/startbutton": {
    "format": "пҢ“",
    "on-click": "ags request -i ags-bundled start-menu '{\"action\":\"toggle\"}'",
    "tooltip": false
  },

  "cpu": {
    "format": "{icon} {usage}% ",
    "tooltip-format": "{usage}%",
    "format-icons": ["о°Ҡ", "оұҲ ", "оұҲ ", "оұҲ ","оұҲ ", "оұҲ ", "оұү ","оұү ", "оұҠ","оұҠ", "оІӯ" ],
    "states": {
      "idle": 0,
      "normal": 10,
      "warning": 70,
      "critical": 90
    },
    "on-click": "~/.config/waybar/scripts/btop-terminal cpu"
  },

  "memory": {
    "format": "{icon} {percentage}%",
    "tooltip-format": "{used:0.1f} GiB / {avail} GiB \n({swapPercentage}% Swap)",
    "format-icons": ["оІӘ"],
    "on-click": "~/.config/waybar/scripts/btop-terminal mem"
  },

  "custom/cpu_temp": {
    "exec": "~/.config/waybar/scripts/temperatures cpu",
    "interval": 30,
    "return-type": "json",
    "format": "п’ј  {}",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/s-tui-terminal"
  },

  "custom/gpu_temp": {
    "exec": "~/.config/waybar/scripts/temperatures gpu",
    "interval": 30,
    "return-type": "json",
    "format": "у°ў®  {}",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/nvitop-terminal"
  },

  "pulseaudio": {
    "format": "{icon} ",
    "format-bluetooth-muted": "у°ҹҺ",
    "format-muted": "оқҸ",
    "icon-size": 20,
    "format-icons": {
      "headphone": "о №",
      "default": ["оҰ’",  "оҰ“", "оҰ”", "оҰ”", "оҰ•", "оҰ•"]
    },
    "on-click": "~/.config/waybar/scripts/wiremix-terminal",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "tooltip": true
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "all-outputs": false
  },

  "hyprland/language": {
    "format": "{}",
    "format-en": "ENG",
    "format-da": "DAN",
    "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next",
  },

  "wlr/taskbar": {
    "format": "{icon}  {title:.25}",
    "markup": true,
    "icon-size": 22,
    "sort-by-app-id": true,
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["vicinae", "Vicinae Launcher"],
    "app_ids-mapping": {
      "WowUp-CF": "wowup-cf",
      "WowUpCf": "wowup-cf",
      "chrome-chat.openai.com__-ChatGPTProfile": "ChatGPT",
      "chrome-music.youtube.com__-YoutubeMusicProfile": "YouTube Music",
      "chrome-www.notion.so__-NotionProfile": "Notion",
      "chrome-mail.proton.me__-ProtonmailProfile": "Proton Mail",
      "chrome-calendar.proton.me__-ProtonCalendarProfile": "Proton Calendar",
      "chrome-photos.corvus-corax.synology.me__-SynologyPhotosProfile": "Synology Photos",
      "chrome-device.realforce.co.jp__-RealforceProfile": "Realforce"
    }
  },
  
  "network": { 
    "interface": "enp0s3",
    "format": "{ifname}",
    "format-wifi": ["оЎІ", "оЎі", "оЎҙ"],
    "format-ethernet": "о №",
    "format-disconnected": "у°ҲӮ",
    "tooltip-format": "{ifname}",
    "on-click": "sh -c 'if pgrep -f \"^nm-connection-editor\" > /dev/null; then pkill -f \"^nm-connection-editor\"; else nm-connection-editor & disown; fi'",
   },

  "clock": {
    "format": "{:>%H:%M\n %d/%m/%Y}",
    "interval": 1,
    "align": 1,
    "justify": "right",
    "on-click": "swaync-client -t",
    "menu": "on-click-right",
    "tooltip": false,
    "menu-file": "~/.config/waybar/power_menu.xml",
    "menu-actions": {
      "shutdown": "shutdown 0",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate",
    }
  },

  "custom/power": {
    "format": "вҸ»",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/power_menu.xml",
    "menu-actions": {
      "shutdown": "shutdown 0",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate",
    }
  },
}
