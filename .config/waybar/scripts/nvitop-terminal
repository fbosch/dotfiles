#!/usr/bin/env bash

set -euo pipefail

class_name="nvitop_terminal"
lock_file="/tmp/nvitop-terminal.lock"
special_workspace="tool_popups"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Check dependencies first (before sourcing lib)
if ! hash nvitop footclient 2>/dev/null; then
  exit 1
fi

# Only source lib if dependencies are available
source "$script_dir/hypr-popup-terminal-lib.sh"

exec 9>"$lock_file"
if command -v flock >/dev/null 2>&1; then
  flock -n 9 || exit 0
fi

launch_nvitop() {
  if footclient -N -a "$class_name" nvitop >/dev/null 2>&1; then
    return
  fi

  foot -a "$class_name" nvitop >/dev/null 2>&1 &
}

if hypr_popup_toggle_or_focus_existing_window "$class_name" "$special_workspace"; then
  exit 0
fi

launch_nvitop
exit 0
