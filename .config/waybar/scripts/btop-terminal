#!/usr/bin/env bash

set -euo pipefail

mode="${1:-cpu}"
special_workspace="tool_popups"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$script_dir/hypr-popup-terminal-lib.sh"

case "$mode" in
  cpu)
    class_name="btop_cpu_terminal"
    lock_file="/tmp/btop-cpu-terminal.lock"
    preset_id="1"
    config_file="$HOME/.config/btop/btop-cpu.conf"
    ;;
  mem)
    class_name="btop_mem_terminal"
    lock_file="/tmp/btop-mem-terminal.lock"
    preset_id="2"
    config_file="$HOME/.config/btop/btop-mem.conf"
    ;;
  *)
    exit 1
    ;;
esac

exec 9>"$lock_file"
if command -v flock >/dev/null 2>&1; then
  flock -n 9 || exit 0
fi

launch_btop() {
  if footclient -N -a "$class_name" btop --config "$config_file" --preset "$preset_id" >/dev/null 2>&1; then
    return
  fi

  foot -a "$class_name" btop --config "$config_file" --preset "$preset_id" >/dev/null 2>&1 &
}

if command -v btop >/dev/null 2>&1 && command -v footclient >/dev/null 2>&1; then
  if hypr_popup_toggle_or_focus_existing_window "$class_name" "$special_workspace"; then
    exit 0
  fi

  launch_btop
  exit 0
fi

exit 1
