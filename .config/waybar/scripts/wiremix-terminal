#!/usr/bin/env bash

set -euo pipefail

class_name="wiremix_terminal"
lock_file="/tmp/wiremix-terminal.lock"
special_workspace="tool_popups"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# Check dependencies first (before sourcing lib)
if ! hash wiremix footclient 2>/dev/null; then
  exit 1
fi

# Only source lib if dependencies are available
source "$script_dir/hypr-popup-terminal-lib.sh"

exec 9>"$lock_file"
if command -v flock >/dev/null 2>&1; then
  flock -n 9 || exit 0
fi

launch_wiremix() {
  local target_workspace existing_window address
  target_workspace="$(hypr_workspace_under_cursor)"

  if footclient -N -a "$class_name" wiremix >/dev/null 2>&1; then
    :
  else
    foot -a "$class_name" wiremix >/dev/null 2>&1 &
  fi

  if [[ -z "$target_workspace" ]]; then
    return
  fi

  existing_window="$(hypr_popup_wait_for_window "$class_name")"
  if [[ -z "$existing_window" ]]; then
    return
  fi

  IFS='|' read -r address _ <<< "$existing_window"
  hyprctl dispatch movetoworkspacesilent "${target_workspace},address:${address}" >/dev/null 2>&1 || true
  hyprctl dispatch focuswindow "address:${address}" >/dev/null 2>&1 || true
}

if hypr_popup_toggle_or_focus_existing_window "$class_name" "$special_workspace"; then
  exit 0
fi

launch_wiremix
exit 0
