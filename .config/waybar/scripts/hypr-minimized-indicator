#!/usr/bin/env bash

set -euo pipefail

readonly TARGET_WORKSPACE="special:minimized"
readonly RECONNECT_DELAY_SECONDS=1

if command -v hyprctl >/dev/null 2>&1; then
  :
else
  printf '{"text":"?","tooltip":"hyprctl not found","class":"error"}\n'
  exit 1
fi

if command -v jq >/dev/null 2>&1; then
  :
else
  printf '{"text":"?","tooltip":"jq not found","class":"error"}\n'
  exit 1
fi

if command -v socat >/dev/null 2>&1; then
  :
else
  printf '{"text":"?","tooltip":"socat not found","class":"error"}\n'
  exit 1
fi

if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
  :
else
  printf '{"text":"?","tooltip":"Not running under Hyprland","class":"error"}\n'
  exit 1
fi

HYPR_SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
if [[ -S "$HYPR_SOCKET" ]]; then
  :
else
  printf '{"text":"?","tooltip":"Hyprland socket unavailable","class":"error"}\n'
  exit 1
fi

get_minimized_count() {
  hyprctl clients -j 2>/dev/null \
    | jq -r --arg workspace "$TARGET_WORKSPACE" '[.[] | select(.workspace.name == $workspace)] | length' 2>/dev/null \
    || printf '0'
}

emit_count() {
  local count="$1"
  local text="󰗧"
  local class_name="empty"
  local tooltip="No minimized windows"

  if (( count > 0 )); then
    text="󰗧 $count"
    class_name="active"
    tooltip="$count minimized window(s)\nClick: toggle minimized workspace"
  fi

  jq -cn \
    --arg text "$text" \
    --arg tooltip "$tooltip" \
    --arg class "$class_name" \
    '{text: $text, tooltip: $tooltip, class: $class}'
}

refresh_if_changed() {
  local count="$1"
  local current_count

  current_count="$(get_minimized_count)"
  if [[ "$current_count" != "$count" ]]; then
    emit_count "$current_count"
    printf '%s' "$current_count"
    return 0
  fi

  printf '%s' "$count"
}

count="-1"
count="$(refresh_if_changed "$count")"

while true; do
  while IFS= read -r _line; do
    count="$(refresh_if_changed "$count")"
  done < <(socat -U - "UNIX-CONNECT:$HYPR_SOCKET")

  sleep "$RECONNECT_DELAY_SECONDS"
done
