#!/usr/bin/env bash

set -euo pipefail

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  printf '%s' "$value"
}

recent_mullvad_failure() {
  local logs

  if ! command -v journalctl >/dev/null 2>&1; then
    return 1
  fi

  logs="$(journalctl -u mullvad-daemon.service --since '15 minutes ago' --no-pager 2>/dev/null || true)"

  if grep -q 'EXPIRED_ACCOUNT' <<<"$logs"; then
    printf 'Account expired. Add time to the Mullvad account, then reconnect.'
    return 0
  fi

  if grep -qi 'Authentication with remote server failed' <<<"$logs"; then
    printf 'Authentication failed. Check the Mullvad account status, then reconnect.'
    return 0
  fi

  if grep -q 'THROTTLED\|429 Too Many Requests' <<<"$logs"; then
    printf 'Mullvad API is rate-limiting checks. Wait a few minutes, then reconnect.'
    return 0
  fi

  return 1
}

emit_status() {
  local status_text="$1"

  if [[ "$status_text" == Connected* ]]; then
    local visible_location
    local relay
    local tooltip

    visible_location="$(printf '%s\n' "$status_text" | awk '/Visible location:/ {sub(/^[[:space:]]*Visible location:[[:space:]]*/, "", $0); print; exit}')"
    relay="$(printf '%s\n' "$status_text" | awk '/Relay:/ {sub(/^[[:space:]]*Relay:[[:space:]]*/, "", $0); print; exit}')"

    tooltip="Mullvad connected"
    if [[ -n "$visible_location" ]]; then
      tooltip+=$'\n'"$visible_location"
    fi
    if [[ -n "$relay" ]]; then
      tooltip+=$'\n'"Relay: $relay"
    fi

    printf '{"text":"󰖂","tooltip":"%s","class":"connected"}\n' "$(json_escape "$tooltip")"
    return 0
  fi

  if [[ "$status_text" == Disconnected* ]]; then
    local failure

    if failure="$(recent_mullvad_failure)"; then
      printf '{"text":"󰖂","tooltip":"%s","class":"error"}\n' "$(json_escape "Mullvad disconnected\n$failure")"
      return 0
    fi

    printf '{"text":"󰖂","tooltip":"Mullvad disconnected","class":"disconnected"}\n'
    return 0
  fi

  printf '{"text":"󰖂","tooltip":"%s","class":"error"}\n' "$(json_escape "$status_text")"
}

print_cli_missing() {
  printf '{"text":"󰖂","tooltip":"Mullvad CLI not found","class":"error"}\n'
}

listen_status() {
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      Connected*|Disconnected*)
        emit_status "$(mullvad status 2>/dev/null || true)"
        ;;
    esac
  done

  if [[ "${line:-}" != "" ]]; then
    emit_status "$(mullvad status 2>/dev/null || true)"
  fi
}

cleanup_listener() {
  trap - EXIT INT TERM
  if [[ -n "${listener_pid:-}" ]]; then
    kill "$listener_pid" 2>/dev/null || true
    wait "$listener_pid" 2>/dev/null || true
  fi
}

stop_listener() {
  cleanup_listener
  exit 0
}

main() {
  local mode="${1:-once}"

  if command -v mullvad >/dev/null 2>&1; then
    if [[ "$mode" == "--listen" ]]; then
      emit_status "$(mullvad status 2>/dev/null || true)"
      if command -v stdbuf >/dev/null 2>&1; then
        coproc MULLVAD_LISTENER { exec stdbuf -oL mullvad status listen 2>/dev/null; }
      else
        coproc MULLVAD_LISTENER { exec mullvad status listen 2>/dev/null; }
      fi

      listener_pid=$MULLVAD_LISTENER_PID
      trap cleanup_listener EXIT
      trap stop_listener INT TERM
      listen_status <&"${MULLVAD_LISTENER[0]}"
      return 0
    fi

    emit_status "$(mullvad status 2>/dev/null || true)"
    return 0
  fi

  print_cli_missing
}

main "$@"
