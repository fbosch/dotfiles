--max-columns=150
--max-columns-preview

--line-number
--no-heading

--smart-case
--color=auto
--no-messages
--threads=4
--max-filesize=2M
--follow

--type-add=web:*.{html,css,js}
# Exclude common heavy or generated trees.
--glob=!.git/**
--glob=!node_modules/**
--glob=!dist/**
--glob=!build/**
--glob=!target/**
--glob=!.next/**
--glob=!.cache/**
--glob=!coverage/**
--glob=!__pycache__/**
--glob=!.pytest_cache/**
--glob=!.backup/**
--glob=!.Trash/**
--glob=!.pnpm-store/**
