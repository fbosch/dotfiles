// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": false,
   "pop_to_root_on_close": true,
   "escape_key_behavior": "close_window",
   "search_files_in_root": false,
   "font": {
      "rendering": "native",
      "normal": {
         "family": "SF Pro Text",
         "size": 10
      }
   },
   "theme": {
      "dark": {
         "name": "zenwritten-dark",
         "icon_theme": "Win11"
      }
   },
   "launcher_window": {
      "opacity": 1,
      "client_side_decorations": {
         "enabled": true,
         "shadow_size": 0
      },
      "blur": {
         "enabled": false
      },
      "compact_mode": {
         "enabled": true
      },
      "layer_shell": {
         "keyboard_interactivity": "on_demand",
         "enabled": true
      }
   },
   "favorites": [
      "applications:protonmail",
      "applications:org.signal.Signal",
      "applications:one.ablaze.floorp",
      "@fbosch/yr-weather:yr-weather",
      "@fbosch/home-assistant:home-assistant-lights",
      "applications:com.discordapp.Discord",
      "@aurelleb/store.vicinae.mullvad:connect",
      "@aurelleb/store.vicinae.mullvad:disconnect",
      "@fbosch/flathub-search:flathub-search",
      "applications:bitwarden",
      "applications:steam",
      "applications:helium-browser",
      "applications:chromium-protonmail",
      "applications:app.zen_browser.zen"
   ],
   "fallbacks": [
      "@knoopx/store.vicinae.nix:packages",
      "@fbosch/flathub-search:flathub-search",
      "@fbosch/kagi-search:kagi-search",
      "files:search"
   ],
   "providers": {
      "@fbosch/home-assistant": {
         "preferences": {
            "baseUrl": "https://ha.corvus-corax.synology.me"
         }
      },
      "@fbosch/wallhaven": {
         "preferences": {
            "useUserSettings": true,
            "downloadDirectory": "~/Pictures/Wallpapers",
            "hyprpaperConfigPath": "~/.config/hypr/hyprpaper.conf",
            "purity": "111",
            "sorting": "relevance",
            "topRange": "3d"
         }
      },
      "@fbosch/wowhead": {
         "entrypoints": {
            "wowhead": {
               "alias": "wh"
            }
         }
      },
      "@fbosch/yr-weather": {
         "preferences": {
            "latitude": "55.704819",
            "longitude": "12.496380"
         }
      },
      "applications": {
         "preferences": {
            "launchPrefix": "uwsm-app --",
            "paths": [
               "/home/fbb/.local/share/applications",
               "/home/fbb/.local/share/flatpak/exports/share/applications",
               "/etc/profiles/per-user/fbb/share/applications",
               "/run/current-system/sw/share/applications"
            ],
            "defaultAction": "launch"
         },
         "entrypoints": {
            "Battle.net": {
               "enabled": true
            },
            "Pokmon Infinite Fusion": {
               "enabled": false
            },
            "app.zen_browser.zen": {
               "alias": "z"
            },
            "battlenet": {
               "alias": "b"
            },
            "btop": {
               "enabled": false
            },
            "chrome-ndcljijdejihfgkgocfgkbffacaljofo-Default": {
               "enabled": false
            },
            "chrome-paeimkinmcfdlknnebjfgiebgemdbegd-Default": {
               "enabled": false
            },
            "chromium-realforce": {
               "enabled": false
            },
            "gvim": {
               "enabled": false
            },
            "htop": {
               "enabled": false
            },
            "hyprprop": {
               "enabled": false
            },
            "io.github.Foldex.AdwSteamGtk": {
               "enabled": true
            },
            "mullvad-vpn": {
               "enabled": false
            },
            "nemo": {
               "alias": "f"
            },
            "net.lutris.battlenet-1": {
               "enabled": false
            },
            "nix.bwrapper.helium_browser": {
               "alias": "h"
            },
            "nvidia-settings": {
               "enabled": true
            },
            "nvim": {
               "enabled": false
            },
            "org.gtk.Demo4": {
               "enabled": false
            },
            "org.gtk.Shaper": {
               "enabled": false
            },
            "org.gtk.WidgetFactory4": {
               "enabled": false
            },
            "org.gtk.gtk4.NodeEditor": {
               "enabled": false
            },
            "org.signal.Signal": {
               "alias": "s"
            },
            "realforce-installer": {
               "enabled": false
            },
            "selectdefaultapplication": {
               "enabled": false
            },
            "tectonic": {
               "enabled": false
            },
            "wine.Programs.Topre REALFORCE CONNECT Software.REALFORCE CONNECT": {
               "enabled": false
            },
            "zen-twilight": {
               "alias": "zt"
            }
         }
      },
      "files": {
         "preferences": {
            "autoIndexing": true,
            "paths": "/home/fbb",
            "excludedPaths": "/home/fbb/Projects/;home/fbb/.local/share/Steam;/home/fbb/.local/share/umu;/home/fbb/.local/share/opencode;/home/fbb/.local/share/pnpm;/home/fbb/.local/share/flatpak;/home/fbb/.var/app;/home/fbb/.npm;/home/fbb/.bun;/home/fbb/.rustup;/home/fbb/.cargo;/home/fbb/.claude",
            "watcherPaths": ""
         }
      },
      "power": {
         "entrypoints": {
            "lock": {
               "preferences": {
                  "customProgram": "hyprlock"
               }
            },
            "power-off": {
               "preferences": {
                  "confirm": true,
                  "customProgram": ""
               }
            },
            "reboot": {
               "preferences": {
                  "confirm": true,
                  "customProgram": ""
               }
            }
         }
      }
   }
}