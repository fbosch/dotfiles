{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "headroom": {
      "type": "local",
      "command": [
        "/home/fbb/.cache/uv/archive-v0/ZhqarDmSBzK-37gI/bin/headroom",
        "mcp",
        "serve"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context",
        "agent",
        "--open-web-dashboard",
        "False"
      ],
      "enabled": true
    }
  },
  "provider": {
    "headroom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Headroom Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1"
      }
    }
  }
}
