{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context",
        "agent",
        "--open-web-dashboard",
        "False"
      ],
      "enabled": true
    },
    "headroom": {
      "type": "local",
      "command": [
        "/home/fbb/.cache/uv/archive-v0/p9XQIra6OSO4G0KL/bin/headroom",
        "mcp",
        "serve"
      ],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1"
      }
    },
    "headroom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Headroom Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "family": "gpt-5",
          "reasoning": true,
          "tool_call": true
        },
        "gpt-5.5-fast": {
          "name": "GPT-5.5 Fast",
          "family": "gpt-5",
          "reasoning": true,
          "tool_call": true
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "family": "gpt-5",
          "reasoning": true,
          "tool_call": true
        },
        "gpt-5.4-mini-fast": {
          "name": "GPT-5.4 Mini Fast",
          "family": "gpt-5",
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  }
}
