{
  "$schema": "https://unpkg.com/opencode-toolbox@0.10.4/toolbox.schema.json",
  "settings": {
    "defaultLimit": 5,
    "initMode": "lazy",
    "connection": {
      "connectTimeout": 30000
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "gh",
        "mcp"
      ]
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-context7",
        "-e",
        "MCP_TRANSPORT=stdio",
        "mcp/context7"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-sequential-thinking",
        "mcp/sequentialthinking"
      ]
    },
    "exa": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-exa",
        "-e",
        "EXA_API_KEY={env:EXA_API_KEY}",
        "mcp/exa"
      ]
    },
    "just-mcp": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-just-mcp",
        "-v",
        ".:/workspace",
        "-w",
        "/workspace",
        "ghcr.io/promptexecution/just-mcp:latest",
        "--stdio"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-chrome-devtools",
        "-e",
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS=true",
        "-e",
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS=true",
        "mcr.microsoft.com/playwright:v1.57.0-noble",
        "npx",
        "-y",
        "chrome-devtools-mcp@1.2.0",
        "--headless",
        "--isolated",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--executable-path=/ms-playwright/chromium-1200/chrome-linux64/chrome",
        "--chrome-arg=--no-sandbox"
      ]
    }
  }
}
