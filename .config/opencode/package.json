{
  "name": "opencode-config-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.15"
  },
  "scripts": {
    "deps:list": "pnpm -r list --depth 0",
    "quality:fallow:mcp": "pnpm --dir mcp/neovim run quality:fallow",
    "quality:fallow:mcp:audit": "pnpm --dir mcp/neovim run quality:fallow:audit"
  },
  "workspaces": [
    "mcp/*",
    "plugins",
    "plugins/*"
  ]
}
