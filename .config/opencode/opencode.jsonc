{
  "$schema": "https://opencode.ai/config.json",
  "theme": "zenwritten-dark",
  "autoupdate": false,
  "disabled_providers": [
    "github-copilot",
    "github-models"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      "**/node_modules/**",
      "**/.devenv/**",
      "**/__pycache__/**",
      "result/**"
    ]
  },
  "plugin": [
    "opencode-toolbox@latest",
    "./plugins/openmemory/openmemory.ts",
    "opencode-wakatime@latest",
    "opencode-toon-plugin@latest",
    "./plugins/rtk.ts",
    "./plugins/opencode-handoff/handoff.ts"
  ],
  "instructions": [
    "~/.config/opencode/instructions/orchestration.md",
    "~/.config/opencode/instructions/reference-loading.md",
    "~/.config/opencode/instructions/RTK.md",
    "~/.config/opencode/instructions/fff.md",
    "~/.config/opencode/instructions/worktrunk.md"
  ],
  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "exec fff-mcp --frecency-db \"${XDG_CACHE_HOME:-$HOME/.cache}/nvim/fff_nvim\""
      ],
      "enabled": true
    },
    "headroom": {
      "type": "local",
      "command": [
        "headroom",
        "mcp",
        "serve"
      ],
      "enabled": false
    }
  },
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "/Users/fbb/.config/opencode/**": "allow"
    },
    "bash": {
      "rm *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "git push *": "deny",
      "git reset *": "deny",
      "git rebase *": "deny",
      "git worktree *": "deny",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git commit *": "deny"
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini-fast",
  "agent": {
    "build": {
      "color": "#6099C0",
      "temperature": 0.3
    },
    "plan": {
      "color": "#B279A7",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "explore": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "general": {
      "steps": 15,
      "temperature": 0.3,
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "title": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "summary": {
      "temperature": 0.1,
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "compaction": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "test": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "review": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "docs": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "research": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "benchmark": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "spec": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "medium"
    },
    "analyze": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "debug": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "ideate": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "patterns": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "adversarial": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "refactor": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "commit": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    }
  }
}
