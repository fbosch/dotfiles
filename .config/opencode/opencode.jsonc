{
  "$schema": "https://opencode.ai/config.json",
  "theme": "zenwritten-dark",
  "autoupdate": false,
  "disabled_providers": [
    "github-copilot",
    "github-models"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      "**/node_modules/**",
      "**/.devenv/**",
      "**/__pycache__/**",
      "result/**"
    ]
  },
  "plugin": [
    "opencode-toolbox@0.10.4",
    [
      "./plugins/context-images/context-images.ts",
      {
        "readResultSources": [
          "~/.config/opencode/TONE.md"
        ],
        "scopedInstructions": true
      }
    ],
    "./plugins/openmemory/openmemory.ts",
    "opencode-wakatime@1.3.8",
    "opencode-toon-plugin@0.1.2",
    "./plugins/headroom-opencode-transport.ts",
    "./plugins/responses-lite-compat/responses-lite-compat.ts",
    "./plugins/rtk.ts",
    "./plugins/opencode-handoff/handoff.ts"
  ],
  "instructions": [
    "~/.config/opencode/instructions/orchestration.md",
    "~/.config/opencode/instructions/fff.md",
    "~/.config/opencode/instructions/worktrunk.md"
  ],
  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "sh",
        "-lc",
        "exec fff-mcp --frecency-db \"${XDG_CACHE_HOME:-$HOME/.cache}/nvim/fff_nvim\""
      ],
      "enabled": true
    },
    "headroom": {
      "type": "local",
      "command": [
        "headroom",
        "mcp",
        "serve"
      ],
      "enabled": true
    }
  },
  "permission": {
    "toolbox_execute": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "~/.config/opencode/**": "allow",
      "/Users/fbb/.config/opencode/**": "allow"
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rtk rm *": "ask",
      "sudo *": "deny",
      "rtk sudo *": "deny",
      "chmod *": "ask",
      "rtk chmod *": "ask",
      "chown *": "ask",
      "rtk chown *": "ask",
      "git push*": "ask",
      "rtk git push*": "ask",
      "git reset*": "ask",
      "rtk git reset*": "ask",
      "git rebase*": "ask",
      "rtk git rebase*": "ask",
      "git worktree*": "ask",
      "rtk git worktree*": "ask",
      "git checkout*": "ask",
      "rtk git checkout*": "ask",
      "git switch*": "ask",
      "rtk git switch*": "ask",
      "git commit*": "ask",
      "rtk git commit*": "ask",
      "git clean*": "ask",
      "rtk git clean*": "ask",
      "git restore*": "ask",
      "rtk git restore*": "ask",
      "git fetch*": "allow",
      "gh pr view*": "allow",
      "gh pr issue*": "allow",
      "gh search*": "allow"
    }
  },
  "model": "openai/gpt-5.6-terra-fast",
  "small_model": "openai/gpt-5.4-mini-fast",
  "agent": {
    "build": {
      "color": "#6099C0",
      "temperature": 0.3
    },
    "plan": {
      "color": "#B279A7",
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "explore": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "general": {
      "steps": 15,
      "temperature": 0.3,
      "model": "openai/gpt-5.6-luna-fast",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "title": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "summary": {
      "temperature": 0.1,
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "compaction": {
      "temperature": 0,
      "model": "openai/gpt-5.6-luna-fast",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "test": {
      "model": "openai/gpt-5.6-luna",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "review": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "docs": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "research": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.6-luna-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "benchmark": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "spec": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "xhigh",
      "textVerbosity": "medium"
    },
    "analyze": {
      "model": "openai/gpt-5.6-terra-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "debug": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "ideate": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "patterns": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "adversarial": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "refactor": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "commit": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    }
  }
}
