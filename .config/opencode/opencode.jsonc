{
  "$schema": "https://opencode.ai/config.json",
  "theme": "zenwritten-dark",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "./plugins/openmemory/openmemory.ts",
    "opencode-wakatime",
    "opencode-handoff",
    "opencode-snippets",
    "opencode-claude-auth",
    "opencode-toon-plugin@latest",
    "./plugins/worktrunk.ts",
    "./plugins/rtk.ts"
  ],
  "instructions": [
    "~/.config/opencode/instructions/worktrunk.md"
  ],
  "permission": {
    "bash": {
      "rm *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "git push *": "deny",
      "git reset *": "deny",
      "git rebase *": "deny",
      "git worktree *": "deny",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git commit *": "deny"
    }
  },
  "agent": {
    "build": {
      "temperature": 0.3
    },
    "plan": {
      "model": "openai/gpt-5.1-codex-max",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "temperature": 0
    },
    "general": {
      "model": "openai/gpt-5.3-codex",
      "steps": 15,
      "temperature": 0.3
    },
    "title": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0
    },
    "summary": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1
    },
    "compaction": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0
    },
    "test": {
      "model": "openai/gpt-5.3-codex"
    },
    "review": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "docs": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "research": {
      "model": "openai/gpt-5.3-codex"
    },
    "quick": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "benchmark": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "spec": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "analyze": {
      "model": "openai/gpt-5.3-codex"
    },
    "debug": {
      "model": "openai/gpt-5.3-codex"
    },
    "ideate": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "patterns": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "adversarial": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "refactor": {
      "model": "openai/gpt-5.3-codex"
    },
    "commit": {
      "model": "openai/gpt-5.1-codex-mini"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-context7",
        "-e",
        "MCP_TRANSPORT=stdio",
        "mcp/context7"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-sequential-thinking",
        "mcp/sequentialthinking"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "gh",
        "mcp"
      ]
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "exa": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "--rm",
        "--replace",
        "--name",
        "mcp-exa",
        "-e",
        "EXA_API_KEY={env:EXA_API_KEY}",
        "mcp/exa"
      ]
    }
  }
}
