{
  "$schema": "https://opencode.ai/config.json",
  "theme": "zenwritten-dark",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-toolbox",
    "./plugins/openmemory/openmemory.ts",
    "opencode-wakatime",
    "opencode-handoff",
    // "opencode-claude-auth",
    "opencode-toon-plugin@latest",
    "./plugins/worktrunk.ts",
    "./plugins/rtk.ts"
  ],
  "instructions": [
    "~/.config/opencode/instructions/worktrunk.md"
  ],
  "permission": {
    "bash": {
      "rm *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "git push *": "deny",
      "git reset *": "deny",
      "git rebase *": "deny",
      "git worktree *": "deny",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git commit *": "deny"
    }
  },
  "agent": {
    "build": {
      "temperature": 0.3
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "openai/codex-mini-latest",
      "temperature": 0
    },
    "general": {
      "model": "openai/gpt-5.3-codex",
      "steps": 15,
      "temperature": 0.3
    },
    "title": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0
    },
    "summary": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0.1
    },
    "compaction": {
      "model": "openai/gpt-5.1-codex-mini",
      "temperature": 0
    },
    "test": {
      "model": "openai/gpt-5.3-codex"
    },
    "review": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "docs": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "research": {
      "model": "openai/gpt-5.3-codex"
    },
    "quick": {
      "model": "github-models/openai/gpt-4.1-nano"
    },
    "benchmark": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "spec": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "analyze": {
      "model": "openai/gpt-5.3-codex"
    },
    "debug": {
      "model": "openai/gpt-5.3-codex"
    },
    "ideate": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "patterns": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "adversarial": {
      "model": "openai/gpt-5.1-codex-max"
    },
    "refactor": {
      "model": "openai/gpt-5.3-codex"
    },
    "commit": {
      "model": "openai/gpt-5.1-codex-mini"
    }
  }
}
