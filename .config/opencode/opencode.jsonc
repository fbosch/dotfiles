{
  "$schema": "https://opencode.ai/config.json",
  "theme": "zenwritten-dark",
  "plugin": [
    "opencode-toolbox",
    "./plugins/openmemory/openmemory.ts",
    "opencode-wakatime",
    "./plugins/rtk.ts",
    "./plugins/opencode-handoff/handoff.ts"
  ],
  "instructions": [
    "~/.config/opencode/instructions/RTK.md",
    "~/.config/opencode/instructions/caveman.md",
    "~/.config/opencode/instructions/orchestration.md",
    "~/.config/opencode/instructions/worktrunk.md"
  ],
  "permission": {
    "bash": {
      "rm *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "git push *": "deny",
      "git reset *": "deny",
      "git rebase *": "deny",
      "git worktree *": "deny",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git commit *": "deny"
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini-fast",
  "agent": {
    "build": {
      "temperature": 0.3
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "explore": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "general": {
      "steps": 15,
      "temperature": 0.3,
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "title": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "summary": {
      "temperature": 0.1,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "compaction": {
      "temperature": 0,
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "test": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "review": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "docs": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "research": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "benchmark": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "spec": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "medium"
    },
    "analyze": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "debug": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "ideate": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "medium"
    },
    "patterns": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    },
    "adversarial": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium"
    },
    "refactor": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "low",
      "textVerbosity": "medium"
    },
    "commit": {
      "model": "openai/gpt-5.4-mini-fast",
      "reasoningEffort": "low",
      "textVerbosity": "low"
    }
  }
}
