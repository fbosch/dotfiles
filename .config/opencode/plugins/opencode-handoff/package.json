{
  "name": "opencode-handoff",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Create focused handoff prompts for continuing work in new OpenCode sessions",
  "author": "Josh Thomas <josh@joshthomas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuadavidthomas/opencode-handoff"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "ai"
  ],
  "main": "handoff.ts",
  "exports": "./handoff.ts",
  "opencode": {
    "type": "plugin",
    "hooks": [
      "config",
      "tool",
      "chat.message",
      "event"
    ]
  },
  "files": [
    "handoff.ts",
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
