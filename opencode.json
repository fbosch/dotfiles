{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/tmp/**": "allow",
      "~/nixos/**": "allow",
      "~/dotfiles/**": "allow",
      "~/.config/**": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**"
    ]
  },
  "mcp": {
    "nvim": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "exec nvim-mcp --connect \"${NVIM_MCP_SOCKET:-auto}\""
      ]
    },
    "design-system": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:6006/mcp"
    }
  }
}
