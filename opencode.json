{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/tmp/**": "allow",
      "~/nixos/**": "allow",
      "~/dotfiles/**": "allow",
      "~/.config/**": "allow",
      "/run/user/1000/**": "allow",
      "~/.cache/opencode/**": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**"
    ]
  },
  "mcp": {
    "design-system": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:6006/mcp"
    }
  },
  "references": {
    "vicinae-docs": {
      "path": ".docs/vicinae-docs",
      "description": "Use for documentation from vicinaehq/docs."
    },
    "ags": {
      "path": ".docs/ags",
      "description": "Use for documentation from Aylur/ags."
    },
    "hyprland-wiki": {
      "path": ".docs/hyprland-wiki",
      "description": "Use for documentation from hyprwm/hyprland-wiki."
    },
    "waybar": {
      "path": ".docs/waybar",
      "description": "Use for documentation from Alexays/Waybar.wiki."
    },
    "glance": {
      "path": ".docs/glance",
      "description": "Use for documentation from glanceapp/glance."
    }
  }
}
